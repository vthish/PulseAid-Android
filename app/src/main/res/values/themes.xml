<resources>
    <style name="Theme.PulseAid" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Brand colors -->
        <item name="colorPrimary">@color/pulse_red</item>
        <item name="colorPrimaryVariant">@color/pulse_red_dark</item>
        <item name="colorSecondary">@color/pulse_red</item>

        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorOnSecondary">@color/surface</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/surface</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- TextInput -->
        <item name="colorControlActivated">@color/pulse_red</item>

        <item name="cornerSize">50%</item>

    </style>
</resources>
