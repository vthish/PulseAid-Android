<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF5F2"
    android:paddingTop="40dp"
    android:paddingBottom="20dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:paddingTop="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Setup Your Donor Profile"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <EditText
            android:id="@+id/donor_input_name"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/profile_input"
            android:backgroundTint="@null"
            android:hint="Full Name"
            android:textColor="#000000"
            android:textColorHint="#757575"
            android:inputType="textPersonName"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

        <EditText
            android:id="@+id/donor_input_nic"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="NIC Number (e.g. 951234567V)"
            android:textColor="#000000"
            android:textColorHint="#757575"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/profile_input"
            android:backgroundTint="@null" />

        <EditText
            android:id="@+id/donor_input_phone"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Phone Number (e.g. 0712345678)"
            android:textColor="#000000"
            android:textColorHint="#757575"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="15dp"
            android:inputType="phone"
            android:background="@drawable/profile_input"
            android:backgroundTint="@null" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="15dp">

            <Spinner
                android:id="@+id/donor_spinner_gender"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:textColor="#000000"
                android:textColorHint="#757575"
                android:theme="@style/Theme.AppCompat.Light"
                android:layout_marginEnd="5dp"
                android:background="@drawable/profile_input"
                android:backgroundTint="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <Spinner
                android:id="@+id/donor_spinner_blood"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:textColor="#000000"
                android:textColorHint="#757575"
                android:theme="@style/Theme.AppCompat.Light"
                android:layout_marginStart="5dp"
                android:background="@drawable/profile_input"
                android:backgroundTint="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="15dp">

            <EditText
                android:id="@+id/donor_input_weight"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:hint="Weight (kg)"
                android:textColor="#000000"
                android:textColorHint="#757575"
                android:inputType="numberDecimal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/profile_input"
                android:backgroundTint="@null" />

            <EditText
                android:id="@+id/donor_input_dob"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:hint="DOB"
                android:textColor="#000000"
                android:textColorHint="#757575"
                android:focusable="false"
                android:clickable="true"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginStart="5dp"
                android:background="@drawable/profile_input"
                android:backgroundTint="@null" />
        </LinearLayout>

        <EditText
            android:id="@+id/donor_input_address"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:hint="Address"
            android:textColor="#000000"
            android:textColorHint="#757575"
            android:padding="20dp"
            android:gravity="top"
            android:layout_marginBottom="27dp"
            android:background="@drawable/profile_input"
            android:backgroundTint="@null"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/btn_save_donor_profile"
            android:layout_width="match_parent"
            android:layout_height="57dp"
            android:text="COMPLETE SETUP"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFF"
            android:textStyle="bold"
            android:background="@drawable/profile_input"
            android:layout_marginBottom="10dp" />

    </LinearLayout>
</ScrollView>