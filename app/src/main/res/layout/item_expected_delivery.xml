<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E3F2FD">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardBackgroundColor="#FFF1F0"
            app:cardCornerRadius="25dp"
            app:strokeWidth="0dp">
            <TextView
                android:id="@+id/tvExpectedBloodGroup"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="O+"
                android:textColor="#D32F2F"
                android:textSize="18sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvExpectedUnits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04 Units Expected"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExpectedSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From: Colombo Blood Bank"
                android:textColor="#757575"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="On the way"
                    android:textColor="#1976D2"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvExpectedETA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ETA: 10:30 AM"
                android:textColor="#F57C00"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>