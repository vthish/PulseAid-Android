<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="30dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/ui_border"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- LEFT INFO -->
        <LinearLayout
            android:id="@+id/infoLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvBloodTypeTag"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvHospitalBankName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tvHospitalBankAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address: Location"
                android:layout_marginTop="4dp"
                android:textSize="13sp"
                android:alpha="0.7"/>

            <TextView
                android:id="@+id/tvHospitalBankContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: 071xxxxxxx"
                android:layout_marginTop="2dp"
                android:textSize="13sp"
                android:textColor="@color/pulse_red_dark"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- BLOOD TYPE TAG -->
        <TextView
            android:id="@+id/tvBloodTypeTag"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/tag_red_background"
            android:gravity="center"
            android:text="O+"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/infoLayout"/>

        <!-- DIVIDER -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="?android:attr/dividerHorizontal"
            android:alpha="0.2"
            app:layout_constraintTop_toBottomOf="@id/infoLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- DISTANCE -->
        <TextView
            android:id="@+id/tvHospitalBankDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2.4 km away"
            android:textColor="@color/pulse_red"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"/>

        <!-- UNITS -->
        <TextView
            android:id="@+id/tvHospitalUnitsToProvide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Units: 05"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>