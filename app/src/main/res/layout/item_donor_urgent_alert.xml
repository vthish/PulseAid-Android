<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_alert_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="15dp"
    app:cardCornerRadius="25dp"
    app:cardElevation="4dp"
    app:strokeColor="#FFCDD2"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TOP: Center Name + Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_center_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hospital Name"
                android:textColor="#333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_alert_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_spinner"
                android:backgroundTint="#E8F5E9"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="RESOLVED"
                android:textColor="#2E7D32"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Blood Group -->
        <TextView
            android:id="@+id/tv_blood_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="B+"
            android:textColor="#D32F2F"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Reason -->
        <TextView
            android:id="@+id/tv_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Reason: Emergency case"
            android:textColor="#555"
            android:textSize="13sp" />

        <!-- Units -->
        <TextView
            android:id="@+id/tv_units"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Required units: 5"
            android:textColor="#777"
            android:textSize="12sp" />

        <!-- Support / Thank you message -->
        <TextView
            android:id="@+id/tv_support_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Thank you message"
            android:textColor="#2E7D32"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Donate Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_donate_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="DONATE NOW"
            android:backgroundTint="#D32F2F"
            android:textColor="@android:color/white"
            app:cornerRadius="30dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>