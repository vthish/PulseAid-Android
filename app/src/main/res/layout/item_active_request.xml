<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cvActiveRequestRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/ui_border"
    app:cardBackgroundColor="?attr/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/llRequestHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvActiveBloodTag">

            <TextView
                android:id="@+id/tvActiveUnits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 Units"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"/>

            <TextView
                android:id="@+id/tvActiveDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested on: --"
                android:textSize="12sp"
                android:alpha="0.6"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvActiveBloodTag"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="@drawable/tag_red_background"
            android:gravity="center"
            android:text="--"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <View
            android:id="@+id/activeDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerHorizontal"
            android:layout_marginTop="16dp"
            android:alpha="0.1"
            app:layout_constraintTop_toBottomOf="@id/llRequestHeader"/>

        <TextView
            android:id="@+id/tvActiveStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Overall Status:"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/activeDivider"/>

        <TextView
            android:id="@+id/tvActiveStatusValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Pending"
            android:textColor="@color/pulse_red"
            android:textStyle="bold"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/tvActiveStatusLabel"
            app:layout_constraintStart_toEndOf="@id/tvActiveStatusLabel"
            app:layout_constraintTop_toTopOf="@id/tvActiveStatusLabel"/>

        <TextView
            android:id="@+id/tvUrgencyTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URGENT"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="@drawable/tag_red_background"
            android:backgroundTint="#D32F2F"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/activeDivider"/>

        <LinearLayout
            android:id="@+id/llBankDetailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp"
            android:background="#0A000000"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvActiveStatusLabel"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bank-wise Progress:"
                android:textSize="11sp"
                android:textStyle="bold"
                android:alpha="0.5"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvTapToView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to view bank details"
            android:textSize="10sp"
            android:alpha="0.4"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/llBankDetailsContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>